{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash|^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/spec-validator.py",
            "timeout": 30,
            "statusMessage": "Checking Virgilio specification-first rule"
          },
          {
            "type": "command",
            "command": "python3 .codex/hooks/git-ready-check.py",
            "timeout": 30,
            "statusMessage": "Checking Virgilio Git safety rule"
          },
          {
            "type": "command",
            "command": "python3 .codex/hooks/backend-ready-check.py",
            "timeout": 30,
            "statusMessage": "Checking Virgilio backend readiness rule"
          }
        ]
      }
    ]
  }
}
